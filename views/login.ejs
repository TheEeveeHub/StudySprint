<%- include('partials/header', { title }) %>

<section class="auth-layout">
	<div class="card auth-card">
		<h1>Welcome Back</h1>
		<p class="muted">Log in to manage your study tasks.</p>

		<% if (validationErrors && validationErrors.length > 0) { %>
			<div class="error-list">
				<% validationErrors.forEach((errorItem) => { %>
					<p><%= errorItem.msg %></p>
				<% }) %>
			</div>
		<% } %>

		<form action="/login" method="POST" class="form-grid">
			<label>
				<span>Email</span>
				<input type="email" name="email" value="<%= oldInput.email || '' %>" required>
			</label>

			<label>
				<span>Password</span>
				<input type="password" name="password" required>
			</label>

			<button type="submit" class="btn btn-full">Login</button>
		</form>

		<p class="switch-link">Need an account? <a href="/register">Create one</a></p>
	</div>
</section>

<%- include('partials/footer') %>
